{
  "name": "@alexeiled/pi-fusion",
  "version": "0.2.3",
  "description": "Stronger answers for hard Pi questions via a parallel model panel + judge, built on pi-subagents",
  "type": "module",
  "main": "./src/index.ts",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-subagents",
    "fusion",
    "multi-agent",
    "multi-model"
  ],
  "files": [
    "agents/*.md",
    "skills/**/*.md",
    "src/*.ts",
    "docs/user-guide.md"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "node --import jiti/register --test test/unit/*.test.ts",
    "test:integration": "node --import jiti/register --test test/integration/*.test.ts",
    "test:e2e": "node --import jiti/register --test test/e2e/*.test.ts",
    "pack:dry": "npm pack --dry-run",
    "publish:dry": "npm publish --dry-run",
    "lint": "eslint . --cache --cache-strategy content",
    "test:all": "npm run lint && npm run check && npm run test:unit && npm run test:integration && npm run test:e2e && npm run pack:dry"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "subagents": {
      "agents": [
        "./agents"
      ]
    },
    "image": "https://raw.githubusercontent.com/alexei-led/pi-fusion/master/docs/assets/fusion-icon.png"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "packageManager": "npm@11.18.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexei-led/pi-fusion.git"
  },
  "homepage": "https://github.com/alexei-led/pi-fusion#readme",
  "bugs": {
    "url": "https://github.com/alexei-led/pi-fusion/issues"
  }
}
